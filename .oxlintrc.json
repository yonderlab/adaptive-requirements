{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": ["./node_modules/ultracite/config/oxlint/core/.oxlintrc.json"],
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**",
    "**/*.config.js",
    "**/*.config.cjs",
    "**/*.config.ts"
  ],
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "typescript/consistent-type-imports": [
      "warn",
      {
        "prefer": "type-imports",
        "fixStyle": "separate-type-imports"
      }
    ],
    "typescript/no-misused-promises": [
      "error",
      {
        "checksVoidReturn": {
          "attributes": false
        }
      }
    ],
    "func-style": "off",
    "sort-keys": "off",
    "no-void": "off",
    "max-statements": "off",
    "no-negated-condition": "off",
    "no-eq-null": "off",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-plusplus": "off",
    "no-nested-ternary": "off",
    "no-inline-comments": "off",
    "no-shadow": "off",
    "default-case": "off",
    "complexity": "off",
    "typescript/no-non-null-assertion": "off",
    "react_perf/jsx-no-new-function-as-prop": "off",
    "no-loop-func": "off",
    "prefer-destructuring": "off",
    "unicorn/no-immediate-mutation": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/no-useless-undefined": "off",
    "oxc/no-accumulating-spread": "off",
    "jest/no-hooks": "off",
    "jest/valid-title": "off",
    "jest/no-conditional-in-test": "off",
    "jest/no-conditional-expect": "off",
    "jest/max-nested-describe": "off",
    "jest/require-top-level-describe": "off"
  },
  "overrides": [
    {
      "files": ["**/*.{test,spec}.{ts,tsx,js,jsx}", "**/__tests__/**/*.{ts,tsx,js,jsx}"],
      "plugins": ["jest", "vitest"],
      "rules": {
        "jest/consistent-test-it": "error",
        "jest/expect-expect": "error",
        "jest/no-alias-methods": "error",
        "jest/no-commented-out-tests": "error",
        "jest/no-disabled-tests": "error",
        "jest/no-done-callback": "error",
        "jest/no-duplicate-hooks": "error",
        "jest/no-export": "error",
        "jest/no-focused-tests": "error",
        "jest/no-identical-title": "error",
        "jest/no-interpolation-in-snapshots": "error",
        "jest/no-jasmine-globals": "error",
        "jest/no-mocks-import": "error",
        "jest/no-standalone-expect": "error",
        "jest/no-test-prefixes": "error",
        "jest/no-test-return-statement": "error",
        "jest/prefer-called-with": "error",
        "jest/prefer-comparison-matcher": "error",
        "jest/prefer-equality-matcher": "error",
        "jest/prefer-expect-resolves": "error",
        "jest/prefer-hooks-in-order": "error",
        "jest/prefer-hooks-on-top": "error",
        "jest/prefer-lowercase-title": "error",
        "jest/prefer-mock-promise-shorthand": "error",
        "jest/prefer-spy-on": "error",
        "jest/prefer-strict-equal": "error",
        "jest/prefer-to-be": "error",
        "jest/prefer-to-contain": "error",
        "jest/prefer-to-have-length": "error",
        "jest/prefer-todo": "error",
        "jest/require-to-throw-message": "error",
        "jest/valid-describe-callback": "error",
        "jest/valid-expect": "error",
        "vitest/consistent-test-filename": "error",
        "vitest/consistent-vitest-vi": "error",
        "vitest/no-conditional-tests": "error",
        "vitest/no-import-node-test": "error",
        "vitest/prefer-to-be-falsy": "error",
        "vitest/prefer-to-be-object": "error",
        "vitest/prefer-to-be-truthy": "error",
        "vitest/require-local-test-context-for-concurrent-snapshots": "error",
        "vitest/warn-todo": "error",
        "vitest/no-importing-vitest-globals": "off",
        "vitest/prefer-describe-function-title": "off",
        "vitest/prefer-expect-type-of": "off",
        "unicorn/no-useless-undefined": "off",
        "jest/no-hooks": "off",
        "jest/valid-title": "off",
        "jest/no-conditional-in-test": "off",
        "jest/no-conditional-expect": "off",
        "jest/max-nested-describe": "off",
        "jest/require-top-level-describe": "off",
        "jest/max-expects": "off",
        "jest/no-large-snapshots": "off",
        "jest/no-restricted-jest-methods": "off",
        "jest/no-restricted-matchers": "off",
        "jest/no-untyped-mock-factory": "off",
        "jest/padding-around-test-blocks": "off",
        "jest/prefer-each": "off",
        "jest/prefer-jest-mocked": "off",
        "jest/prefer-to-have-been-called": "off",
        "jest/prefer-to-have-been-called-times": "off",
        "jest/no-confusing-set-timeout": "off",
        "jest/no-deprecated-functions": "off",
        "jest/require-hook": "off",
        "react/button-has-type": "off"
      }
    }
  ]
}
