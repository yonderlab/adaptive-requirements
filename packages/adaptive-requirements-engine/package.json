{
  "name": "@kotaio/adaptive-requirements-engine",
  "version": "2.1.1",
  "description": "Schema-driven requirements engine with JSON Logic rules for conditional evaluation, validation, and computed fields",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yonderlab/adaptive-requirements.git",
    "directory": "packages/adaptive-requirements-engine"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./test-fixtures/claims-submission": {
      "types": "./dist/test-fixtures/claims-submission.d.ts",
      "default": "./dist/test-fixtures/claims-submission.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf node_modules dist",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "json-logic-js": "2.0.5",
    "libphonenumber-js": "^1.11.20"
  },
  "devDependencies": {
    "@tsconfig/recommended": "^1.0.8",
    "@tsconfig/strictest": "^2.0.5",
    "@types/json-logic-js": "^2.0.8",
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "tsdown": "^0.21.9",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
