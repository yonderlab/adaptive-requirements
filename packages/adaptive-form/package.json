{
  "name": "@kotaio/adaptive-form",
  "version": "1.2.1",
  "description": "A lightweight, type-safe adaptive form system for React with JSON-Logic for conditional fields, dynamic validation, and computed values",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yonderlab/adaptive-requirements.git",
    "directory": "packages/adaptive-form"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/react/index.js",
  "types": "./dist/react/index.d.ts",
  "exports": {
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./react/adapters/react-hook-form": {
      "types": "./dist/react/adapters/react-hook-form.d.ts",
      "default": "./dist/react/adapters/react-hook-form.js"
    },
    "./react/adapters/formik": {
      "types": "./dist/react/adapters/formik.d.ts",
      "default": "./dist/react/adapters/formik.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "clean": "git clean -xdf node_modules dist",
    "dev": "tsdown --watch",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kotaio/adaptive-requirements-engine": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@tsconfig/recommended": "^1.0.8",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^25.2.3",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "3.2.4",
    "jsdom": "^28.1.0",
    "tsdown": "^0.20.3",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1"
  }
}
